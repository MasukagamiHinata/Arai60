#### 問題 142. Linked List Cycle II (https://leetcode.com/problems/linked-list-cycle-ii/)

#### step1
# 方針はLinked List Cycleと変わらないはず(setを用いて素直に解く)。返り値の型を変えるだけだろう。
class Solution:
    def detectCycle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        if head is None or head.next is None:
            return None
        nodes_seen = set()
        current = head
        while current is not None:
            if current in nodes_seen:
                return current
            nodes_seen.add(current)
            current = current.next
        return None

# 時間計算量: O(n) 最悪の場合、訪問するノード数はnであるため。
# 空間計算量: O(n) 最悪の場合、n個のノードすべてがset()に追加されるため。

# フロイドのアルゴリズムでも一応解いてみる
class Solution:
    def detectCycle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        fast = head
        slow = head
        while fast and fast.next:
            fast = fast.next.next
            slow = slow.next
            if fast is slow:
                break
        if fast is None or fast.next is None:
            return None
        
        slow = head
        while fast is not slow:
            fast = fast.next
            slow = slow.next
        return fast


