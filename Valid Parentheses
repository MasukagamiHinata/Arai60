class Solution:
    def isValid(self, s: str) -> bool:
        end_index = self._check_validity(s, 0, correspond_brackets, open_brackets)
        return end_index == len(s)

    def _check_validity(self, s: str, i: int, correspond_brackets: dict, open_brackets: set) -> int:
        n = len(s)

        if i == n:
            return i

        j = i
        while j < n:
            char = s[j]
            if char in open_brackets:
                #初めの開きカッコ以降を部下（再帰で呼び出される関数）に任せる
                next_start_index = self._check_validity(s, j + 1, correspond_brackets, open_brackets)

                # 子関数（中身）が無効なら、直ちに -1 を返す
                if next_start_index == -1:
                    return -1 

                # カッコどうしの対応を確認
                # if char in open_brackets:のもとなのだが、下のelifから返されたインデックス[j]（最後の開きカッコの場所）
                # を基準にカッコの対応を確認する
                expected_close = correspond_brackets[char] #charに対応する閉じカッコ
                j = next_start_index 
                if j < n:
                    # 対応するならjのカウントを１上げる
                    if s[j] == expected_close:
                        j += 1
                    else:
                        return -1
                else:
                    return -1

            elif char in correspond_brackets.values():
                # 閉じ括弧の場合：上階層の関数（親の開き括弧）に「ここまで処理しました」と報告
                # 親の関数が自分の閉じ括弧を見つけたことを報告するため、
                # 現在のインデックス j を返して処理を中断する
                return j 
                
            else:
                # 括弧以外の文字：スキップして次の文字へ
                j += 1
                
        # ループ終了：最後まで処理できた場合、終端インデックスを返す
        return j


