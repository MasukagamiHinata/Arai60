class Solution:
    def reverselist(self, head: Optional[ListNode]) -> Optional[ListNode]:
        node = None 
        
        while head:
            storage = head.next # tempのみだと推測しづらいので。
            head.next = node 
            node = head 
            head = storage 

        return node

